# ── Production (Render) ─────────────────────────────────────────────
# Used by EAS preview/production builds (also set in eas.json).
EXPO_PUBLIC_API_URL=https://agri-clinic-backend.onrender.com/api/v1/

# ── Local dev only ──────────────────────────────────────────────────
# Copy this file to .env.local (gitignored) and uncomment:
# EXPO_PUBLIC_DEV_API_URL=http://192.168.29.18:8000/api/v1/
#
# Force cloud API during local Expo dev:
# EXPO_PUBLIC_USE_PRODUCTION_API=1
