# Copy to .env.local and set your PC LAN IPv4 (ipconfig → Wi-Fi IPv4 Address).
# Phone must be on the SAME Wi-Fi as the PC (not mobile data only). Django:
#   python manage.py runserver 0.0.0.0:8000
EXPO_PUBLIC_DEV_API_URL=http://192.168.29.18:8000/api/v1/
#
# If the app says "no internet" but Wi-Fi works, the phone cannot reach 192.168.x.x —
# fix firewall / same Wi-Fi, OR use cloud API for testing:
# EXPO_PUBLIC_USE_PRODUCTION_API=1
#
# Expo Go: use `npm start` (tunnel). LAN-only `expo start` often fails QR scan on some networks.
