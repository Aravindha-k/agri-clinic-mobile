{
  "name": "agri-clinic-field-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-for-phone.ps1",
    "start:phone": "powershell -ExecutionPolicy Bypass -File ./scripts/start-for-phone.ps1",
    "start:phone:clear": "powershell -ExecutionPolicy Bypass -File ./scripts/start-for-phone.ps1 -Clear",
    "start:lan": "expo start --lan",
    "start:clear": "powershell -ExecutionPolicy Bypass -File ./scripts/start-for-phone.ps1 -Clear",
    "start:tunnel": "expo start --tunnel",
    "start:tunnel:clear": "expo start --tunnel -c",
    "start:usb": "powershell -ExecutionPolicy Bypass -File ./scripts/expo-adb-usb.ps1",
    "android": "expo run:android",
    "android:device": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:api": "node scripts/verify-production-api.mjs",
    "verify:deploy": "node scripts/audit-deploy-config.mjs",
    "verify:apk": "node scripts/audit-apk-release.mjs",
    "icons:generate": "node scripts/generate-app-icons.mjs && node scripts/generate-splash-logo.mjs",
    "download:splash-video": "curl -L \"https://www.pexels.com/download/video/6592618/\" -o assets/splash/rice-paddy.mp4",
    "import:water-pour-sound": "node scripts/import-water-pour-sound.mjs",
    "import:heat-sound": "node scripts/import-heat-sound.mjs",
    "sync:notification-sounds": "node scripts/sync-notification-sounds.mjs",
    "postinstall": "node scripts/import-water-pour-sound.mjs && node scripts/import-heat-sound.mjs && node scripts/sync-notification-sounds.mjs",
    "verify:api:local": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-local-api.ps1",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:apk": "eas build --platform android --profile preview --non-interactive",
    "build:apk:prod": "eas build --platform android --profile production --non-interactive",
    "build:aab": "eas build --platform android --profile production-aab --non-interactive"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.17.0",
    "babel-preset-expo": "~54.0.10",
    "dayjs": "^1.11.21",
    "expo": "~54.0.35",
    "expo-av": "~16.0.8",
    "expo-battery": "~10.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-screen-capture": "~8.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "audio-decode": "^3.10.2",
    "sharp": "^0.35.1",
    "typescript": "~5.9.2",
    "wav-encoder": "^1.3.0"
  }
}
